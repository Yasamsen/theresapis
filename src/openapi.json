      }
    ],
    "responses": {
      "200": {
        "description": "Berhasil",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "boolean", "example": true },
                "result": {
                  "type": "object",
                  "properties": {
                    "original": { "type": "string", "example": "https://videy.com/v?id=123abc" },
                    "video": { "type": "string", "example": "https://cdn.videy.com/v?id=123abc.mp4" },
