{
  "openapi": "1.0.0",
  "info": {
    "title": "Theresa",
    "author": "yasamDev",
    "version": "v1.0.0",
    "description": "Simple and easy to use API."
  },
  "servers": [
    { "url": "/" }
  ],
  "tags": [
    { "name": "AI" },
    { "name": "Anime" },
    { "name": "Downloader" },
    { "name": "Image" },
   { "name": "News" },
   { "name": "Tools" },
   { "name": "Search" },
   { "name": "Cloudflare" }    
     
  ],
  "paths": {
      "/ai/copilot": {
  "get": {
    "summary": "Copilot Chat",
    "description": "Kirim pertanyaan ke Copilot Microsoft dan dapatkan jawaban beserta referensi/citations",
    "tags": ["AI"],
    "parameters": [
      {
        "name": "message",
        "in": "query",
        "required": true,
        "description": "Pesan atau pertanyaan yang ingin dikirim ke Copilot",
        "schema": { "type": "string" }
      },
      {
        "name": "model",
        "in": "query",
        "required": false,
        "description": "Model Copilot yang digunakan (default: 'default', opsional: 'think-deeper', 'gpt-5')",
        "schema": { "type": "string", "enum": ["default", "think-deeper", "gpt-5"], "default": "default" }
      }
    ],
    "responses": {
      "200": {
        "description": "Berhasil mendapatkan jawaban dari Copilot",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "text": { "type": "string", "example": "Berikut adalah berita terbaru dari Indonesia..." },
                "citations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "title": { "type": "string", "example": "Detik News" },
                      "icon": { "type": "string", "example": "https://example.com/icon.png" },
                      "url": { "type": "string", "format": "uri", "example": "https://www.detik.com/..." }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "400": {
        "description": "Request invalid, message kosong",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "boolean", "example": false },
                "error": { "type": "string", "example": "Message wajib diisi" }
              }
            }
          }
        }
      },
      "500": {
        "description": "Gagal memproses request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "boolean", "example": false },
                "error": { "type": "string", "example": "Gagal memproses request" }
              }
            }
          }
        }
      }
    }
  }
},
"/ai-image/nanoedit": {
  "get": {
    "summary": "AI Image NanoEdit",
    "description": "Mengedit gambar menggunakan AI dan mengembalikan URL hasil edit.",
    "tags": ["AI Image"],
    "parameters": [
      {
        "in": "query",
        "name": "url",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "URL gambar"
      },
      {
        "in": "query",
        "name": "prompt",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Prompt edit gambar"
      }
    ],
    "responses": {
      "200": {
        "description": "Berhasil mengedit gambar",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "boolean",
                  "example": true
                },
                "task_id": {
                  "type": "string",
                  "example": "cd1be7a6ae63b174b5e53e5065c57974"
                },
                "result": {
                  "type": "string",
                  "example": "https://temp.live3d.io/...webp"
                }
              }
            }
          }
        }
      },
      "400": {
        "description": "Parameter tidak lengkap"
      },
      "500": {
        "description": "Server error"
      }
    }
  }
},
"/ai-image/editfoto": {
  "get": {
    "summary": "AI Edit Foto",
